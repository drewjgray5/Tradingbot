# Discord notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Your Discord user ID for error pings (leave empty to skip mention)
DISCORD_USER_ID=your_discord_user_id

# Trade confirmation bot (Approve/Reject buttons before executing)
# Create app at discord.com/developers, add Bot, invite with scopes: bot, applications.commands
DISCORD_BOT_TOKEN=your_bot_token
DISCORD_CONFIRM_CHANNEL_ID=1234567890123456789
# Optional: Server/Guild ID for instant slash command sync (right-click server -> Copy ID, need Dev Mode)
# DISCORD_GUILD_ID=1234567890123456789

# Schwab Market Data API (OHLCV, quotes)
SCHWAB_MARKET_APP_KEY=your_market_app_key
SCHWAB_MARKET_APP_SECRET=your_market_app_secret

# Schwab Account API (orders, balances)
SCHWAB_ACCOUNT_APP_KEY=your_account_app_key
SCHWAB_ACCOUNT_APP_SECRET=your_account_app_secret

# OAuth callback (must match app registration)
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182

# Account hash for orders (optional). If "Invalid account number" on trades, fetch from
# Schwab Developer Portal or run: python scripts/get_account_hash.py
# SCHWAB_ACCOUNT_HASH=

# Position size per signal trade (dollar amount). Default: 500
# POSITION_SIZE_USD=500

# Hold period (days) before "consider selling" reminder. Default: 20
# HOLD_DAYS=20

# Guardrails (optional; defaults: 500k total, 50k per ticker, 20 trades/day)
# MAX_TOTAL_ACCOUNT_VALUE=500000
# MAX_POSITION_PER_TICKER=50000
# MAX_TRADES_PER_DAY=20

# Sector filter: only trade sectors outperforming SPY (set to false to disable)
# SECTOR_FILTER_ENABLED=true

# Execution mode: when true, computes guardrails/filters but does NOT place live orders.
# Useful for shadow rollout and validation before going live.
# EXECUTION_SHADOW_MODE=false

# Protective trailing stop order duration for BUY fills.
# Allowed: DAY or GOOD_TILL_CANCEL
# STOP_ORDER_DURATION=GOOD_TILL_CANCEL

# --- Deterministic / configurable params ---

# Stage 2: price within this fraction of 52w high (0.85 = within 15%)
# STAGE2_52W_PCT=0.85
# Stage 2: 200 SMA upward for N days
# STAGE2_SMA_UPWARD_DAYS=20
# VCP: consecutive days volume below 50d avg
# VCP_DAYS=4

# Signal ranking: max signals to send (0 = no limit). Sorted by setup score.
# SIGNAL_TOP_N=5
# Strategy plugins / ensemble (shadow-first defaults)
# STRATEGY_PULLBACK_MODE=shadow          # off|shadow|live
# STRATEGY_REGIME_ROUTER_MODE=shadow     # off|shadow|live
# STRATEGY_ENSEMBLE_MODE=shadow          # off|shadow|live
# Regime-router weights by strategy and regime bucket
# STRATEGY_WEIGHT_BREAKOUT_HIGH=1.00
# STRATEGY_WEIGHT_BREAKOUT_MED=1.00
# STRATEGY_WEIGHT_BREAKOUT_LOW=0.95
# STRATEGY_WEIGHT_PULLBACK_HIGH=0.90
# STRATEGY_WEIGHT_PULLBACK_MED=1.05
# STRATEGY_WEIGHT_PULLBACK_LOW=1.10
# Two-stage scanner parallelism + shortlist controls
# SCAN_STAGE_A_MAX_WORKERS=8
# SCAN_STAGE_B_MAX_WORKERS=2
# SCAN_STAGE_A_SHORTLIST_MULTIPLIER=3.0
# SCAN_STAGE_A_SHORTLIST_CAP=40
# SCAN_STAGE_TASK_TIMEOUT_SEC=120
# SCAN_ALLOW_BEAR_REGIME=false            # true = run scans even if SPY < 200 SMA

# Signal quality gates (optional; disabled by default for safe rollout)
# QUALITY_GATES_ENABLED=false
# QUALITY_GATES_MODE=soft                  # off|shadow|soft|hard
# QUALITY_SOFT_MIN_REASONS=2
# QUALITY_MIN_SIGNAL_SCORE=50
# QUALITY_MIN_CONTINUATION_PROB=0.55
# QUALITY_MAX_BULL_TRAP_PROB=0.45
# QUALITY_REQUIRE_BREAKOUT_VOLUME=false
# QUALITY_BREAKOUT_VOLUME_MIN_RATIO=0.90

# Forensic accounting filters (shadow-first rollout)
# FORENSIC_ENABLED=true
# FORENSIC_FILTER_MODE=shadow     # off|shadow|soft|hard
# FORENSIC_SLOAN_MAX=0.10
# FORENSIC_BENEISH_MAX=-1.78
# FORENSIC_ALTMAN_MIN=1.80
# FORENSIC_CACHE_HOURS=24

# PEAD (post-earnings drift) score adjustments
# PEAD_ENABLED=true
# PEAD_LOOKBACK_DAYS=10
# PEAD_SCORE_BOOST=3.0
# PEAD_SCORE_BOOST_LARGE=5.0
# PEAD_SCORE_PENALTY=3.0

# Filing guidance tone score adjustments
# GUIDANCE_SCORE_ENABLED=true
# GUIDANCE_SCORE_BOOST=2.0
# GUIDANCE_SCORE_PENALTY=2.0

# Breakout confirmation: require intraday price above prior day high
# BREAKOUT_CONFIRM_ENABLED=true
# Minutes from midnight for confirmation (570 = 9:30 AM ET)
# BREAKOUT_CONFIRM_MIN_TIME=570

# Volatility-based position sizing (ATR). When true, sizes by volatility.
# VOLATILITY_SIZING_ENABLED=false
# Base risk USD when ATR_mult=1
# VOLATILITY_BASE_USD=5000
# Target ATR multiple for stop (2.0 = 2 ATR risk per trade)
# VOLATILITY_ATR_MULT=2.0

# Data: log warning when yfinance fallback used (Schwab failed)
# PREFER_SCHWAB_DATA=true

# Demo mode: DEMO_SIGNAL=1 forces a test signal (AAPL + MiroFish) to verify full flow. No real order.
# DEMO_SIGNAL=1

# --- Signal scan watchlist (signal_scanner._load_watchlist) ---
# Default: full dynamic list from watchlist_loader — S&P 500 + 400 + 600 + Russell 2000 + IWM (~3k tickers, cached 24h in .watchlist_cache.json).
# USE_STATIC_WATCHLIST=true  — built-in DEFAULT_WATCHLIST only (~230 tickers) for faster scans.
# SIGNAL_WATCHLIST=AAPL,MSFT — if set, overrides static/full (comma-separated).
# QUALITY_WATCHLIST_PREFILTER_ENABLED=false
# QUALITY_WATCHLIST_PREFILTER_MAX=800

# SEC enrichment rollout defaults (informational + shadow-first)
# SEC_ENRICHMENT_ENABLED=true
# SEC_TAGGING_ENABLED=true
# SEC_SHADOW_MODE=true
# SEC_SCORE_HINT_ENABLED=false
# SEC_CACHE_HOURS=12
# EDGAR_USER_AGENT=YourName your-email@example.com

# Optional: custom encryption key for token files
# SCHWAB_TOKEN_ENCRYPTION_KEY=...

# Self-study: learn from trade outcomes, adjust MiroFish conviction threshold
# SELF_STUDY_ENABLED=true  # Set to enable learned min conviction filter on signals

# Simulation viewer: local URL for interactive social graph (link shown in Discord)
# SIMULATION_VIEWER_URL=http://localhost:3000

# MiroFish / Agent simulation (engine_analysis.py)
# LLM for agent personas (OpenAI or Qwen). OPENAI_API_KEY also works.
MIROFISH_API_KEY=sk-your-openai-or-qwen-api-key
# Leave empty for OpenAI; for Qwen: https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=
LLM_MODEL_NAME=gpt-4o-mini
# Zep for agent memory (optional)
ZEP_API_KEY=

# Advisory model (Phase 1): predicts P(up over next 10 trading days), advisory-only.
# ADVISORY_MODEL_ENABLED=true
# ADVISORY_MODEL_PATH=artifacts/advisory_model_v1.json
# ADVISORY_CONFIDENCE_HIGH=0.62
# ADVISORY_CONFIDENCE_LOW=0.52
# ADVISORY_REQUIRE_MODEL=false
